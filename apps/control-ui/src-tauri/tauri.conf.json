{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ToskLight",
  "version": "0.1.0",
  "identifier": "de.tokenet.light",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4175",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../../.artifacts/build/frontend/control-ui"
  },
  "app": {
    "windows": [
      {
        "title": "ToskLight",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "decorations": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../assets/fixture-library/": "fixture-library/"
    }
  }
}
