{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ToskLight Hardware Controls",
  "version": "0.1.0",
  "identifier": "de.tokenet.tosklight.hardware-controls",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4176",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../../../.artifacts/build/frontend/hardware-controls"
  },
  "app": {
    "windows": [
      {
        "title": "ToskLight Hardware Controls",
        "width": 1600,
        "height": 950,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
