{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node tools/set-version.mjs ${nextRelease.version} && cargo update --workspace --offline"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "apps/control-ui/package.json",
          "apps/control-ui/src-tauri/tauri.conf.json",
          "apps/hardware-controls/package.json",
          "apps/hardware-controls/src-tauri/tauri.conf.json",
          "Cargo.toml",
          "Cargo.lock",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
