{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SelectiveImportErrorResponse",
  "type": "object",
  "properties": {
    "current_revision": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "error": {
      "type": "string"
    },
    "retryable": {
      "type": "boolean"
    }
  },
  "required": [
    "error",
    "current_revision",
    "retryable"
  ]
}
