{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlaybackEventSnapshot",
  "type": "object",
  "properties": {
    "cursor": {
      "$ref": "#/$defs/EventSnapshotCursor"
    },
    "desk_id": {
      "type": "string",
      "format": "uuid"
    },
    "playbacks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PlaybackStateSnapshot"
      }
    }
  },
  "required": [
    "desk_id",
    "cursor",
    "playbacks"
  ],
  "$defs": {
    "CueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "EventCapability": {
      "type": "string",
      "enum": [
        "programmer",
        "playback",
        "show",
        "desk",
        "output",
        "system"
      ]
    },
    "EventObject": {
      "type": "object",
      "properties": {
        "capability": {
          "$ref": "#/$defs/EventCapability"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "capability",
        "id"
      ]
    },
    "EventSnapshotCursor": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "sequence"
      ]
    },
    "PlaybackStateSnapshot": {
      "type": "object",
      "properties": {
        "cue_list_id": {
          "type": "string",
          "format": "uuid"
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "loaded": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "object": {
          "$ref": "#/$defs/EventObject"
        },
        "paused": {
          "type": "boolean"
        },
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "object",
        "playback_number",
        "cue_list_id",
        "current",
        "loaded",
        "paused",
        "enabled"
      ]
    }
  }
}
