{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventServerMessage",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "cursor": {
          "$ref": "#/$defs/EventSnapshotCursor"
        },
        "type": {
          "type": "string",
          "const": "ready"
        }
      },
      "required": [
        "type",
        "cursor"
      ]
    },
    {
      "type": "object",
      "properties": {
        "event": {
          "$ref": "#/$defs/EventEnvelope"
        },
        "type": {
          "type": "string",
          "const": "event"
        }
      },
      "required": [
        "type",
        "event"
      ]
    },
    {
      "type": "object",
      "properties": {
        "gap": {
          "$ref": "#/$defs/SequenceGap"
        },
        "type": {
          "type": "string",
          "const": "gap"
        }
      },
      "required": [
        "type",
        "gap"
      ]
    },
    {
      "type": "object",
      "properties": {
        "cursor": {
          "$ref": "#/$defs/EventSnapshotCursor"
        },
        "type": {
          "type": "string",
          "const": "repaired"
        }
      },
      "required": [
        "type",
        "cursor"
      ]
    },
    {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "error"
        }
      },
      "required": [
        "type",
        "error"
      ]
    }
  ],
  "$defs": {
    "CueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "EventActionSource": {
      "type": "string",
      "enum": [
        "user_interface",
        "keyboard",
        "osc",
        "http",
        "midi",
        "matter",
        "cue",
        "timecode",
        "scheduler",
        "macro",
        "system"
      ]
    },
    "EventCapability": {
      "type": "string",
      "enum": [
        "programmer",
        "playback",
        "show",
        "desk",
        "output",
        "system"
      ]
    },
    "EventClass": {
      "type": "string",
      "enum": [
        "transition",
        "projection",
        "command_outcome",
        "error",
        "safety",
        "telemetry"
      ]
    },
    "EventDeliveryPolicy": {
      "type": "string",
      "enum": [
        "lossless",
        "replaceable"
      ]
    },
    "EventEnvelope": {
      "type": "object",
      "properties": {
        "class": {
          "$ref": "#/$defs/EventClass"
        },
        "correlation_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "delivery": {
          "$ref": "#/$defs/EventDeliveryPolicy"
        },
        "desk_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "object": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventObject"
            },
            {
              "type": "null"
            }
          ]
        },
        "occurred_at": {
          "type": "string"
        },
        "payload": {
          "$ref": "#/$defs/EventPayload"
        },
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "source": {
          "$ref": "#/$defs/EventSource"
        }
      },
      "required": [
        "sequence",
        "occurred_at",
        "desk_id",
        "class",
        "object",
        "source",
        "correlation_id",
        "delivery",
        "payload"
      ]
    },
    "EventObject": {
      "type": "object",
      "properties": {
        "capability": {
          "$ref": "#/$defs/EventCapability"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "capability",
        "id"
      ]
    },
    "EventPayload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "transition": {
              "$ref": "#/$defs/PlaybackCueTransition"
            },
            "type": {
              "type": "string",
              "const": "playback_cue_transition"
            }
          },
          "required": [
            "type",
            "transition"
          ]
        },
        {
          "type": "object",
          "properties": {
            "delta": {
              "$ref": "#/$defs/PatchDelta"
            },
            "type": {
              "type": "string",
              "const": "show_patch_changed"
            }
          },
          "required": [
            "type",
            "delta"
          ]
        },
        {
          "type": "object",
          "properties": {
            "change": {
              "$ref": "#/$defs/OutputRouteChange"
            },
            "type": {
              "type": "string",
              "const": "output_route_changed"
            }
          },
          "required": [
            "type",
            "change"
          ]
        },
        {
          "type": "object",
          "properties": {
            "change": {
              "$ref": "#/$defs/ShowObjectsChange"
            },
            "type": {
              "type": "string",
              "const": "show_objects_changed"
            }
          },
          "required": [
            "type",
            "change"
          ]
        }
      ]
    },
    "EventSnapshotCursor": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "sequence"
      ]
    },
    "EventSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "runtime"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "action"
            },
            "source": {
              "$ref": "#/$defs/EventActionSource"
            }
          },
          "required": [
            "kind",
            "source"
          ]
        }
      ]
    },
    "OutputDeliveryMode": {
      "type": "string",
      "enum": [
        "broadcast",
        "multicast",
        "unicast"
      ]
    },
    "OutputProtocol": {
      "type": "string",
      "enum": [
        "art_net",
        "sacn"
      ]
    },
    "OutputRoute": {
      "type": "object",
      "properties": {
        "delivery_mode": {
          "$ref": "#/$defs/OutputDeliveryMode"
        },
        "destination": {
          "type": [
            "string",
            "null"
          ]
        },
        "destination_universe": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "logical_universe": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "minimum_slots": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "protocol": {
          "$ref": "#/$defs/OutputProtocol"
        }
      },
      "required": [
        "protocol",
        "logical_universe",
        "destination_universe",
        "delivery_mode",
        "destination",
        "enabled",
        "minimum_slots"
      ]
    },
    "OutputRouteChange": {
      "type": "object",
      "properties": {
        "deleted": {
          "type": "boolean"
        },
        "object_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "route": {
          "anyOf": [
            {
              "$ref": "#/$defs/OutputRoute"
            },
            {
              "type": "null"
            }
          ]
        },
        "route_id": {
          "type": "string"
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision",
        "route_id",
        "object_revision",
        "route",
        "deleted"
      ]
    },
    "PatchDelta": {
      "description": "Targeted post-mutation projection suitable for a Patch store and a typed patch-change event.",
      "type": "object",
      "properties": {
        "event_sequence": {
          "description": "Sequence of the semantic patch-change event, absent for a no-op desired-state request.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fixtures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchFixtureProjection"
          }
        },
        "patch_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "profile_revisions": {
          "description": "Unique metadata needed to interpret the fixture projections in this delta.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchProfileRevisionProjection"
          }
        },
        "removed_fixture_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision",
        "patch_revision",
        "event_sequence",
        "fixtures",
        "removed_fixture_ids",
        "profile_revisions"
      ]
    },
    "PatchDirectControlEndpoint": {
      "type": "object",
      "properties": {
        "ip_address": {
          "description": "Transport adapters validate this as an IP address before invoking the application service.",
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "protocol": {
          "$ref": "#/$defs/PatchDirectControlProtocol"
        }
      },
      "additionalProperties": false,
      "required": [
        "protocol",
        "ip_address",
        "port"
      ]
    },
    "PatchDirectControlProtocol": {
      "type": "string",
      "enum": [
        "citp"
      ]
    },
    "PatchFixtureLocation": {
      "description": "Stage position in integer millimetres.",
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "format": "int32"
        },
        "y": {
          "type": "integer",
          "format": "int32"
        },
        "z": {
          "type": "integer",
          "format": "int32"
        }
      },
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ]
    },
    "PatchFixtureProjection": {
      "description": "Portable, authoritative Patch representation of one fixture without an inline definition.",
      "type": "object",
      "properties": {
        "direct_control": {
          "anyOf": [
            {
              "$ref": "#/$defs/PatchDirectControlEndpoint"
            },
            {
              "type": "null"
            }
          ]
        },
        "fixture_id": {
          "type": "string",
          "format": "uuid"
        },
        "fixture_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "fixture_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "highlight_overrides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchHighlightOverrideProjection"
          }
        },
        "layer_id": {
          "type": "string"
        },
        "location": {
          "$ref": "#/$defs/PatchFixtureLocation"
        },
        "logical_heads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchLogicalHeadProjection"
          }
        },
        "mode_id": {
          "type": "string",
          "format": "uuid"
        },
        "move_in_black_delay_millis": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "move_in_black_enabled": {
          "type": "boolean"
        },
        "multipatch": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchMultiPatchProjection"
          }
        },
        "name": {
          "type": "string"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "profile_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "rotation": {
          "$ref": "#/$defs/PatchFixtureRotation"
        },
        "split_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchSplitAssignment"
          }
        },
        "virtual_fixture_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "fixture_id",
        "fixture_revision",
        "fixture_number",
        "virtual_fixture_number",
        "name",
        "profile_id",
        "profile_revision",
        "mode_id",
        "split_patches",
        "layer_id",
        "direct_control",
        "location",
        "rotation",
        "logical_heads",
        "multipatch",
        "move_in_black_enabled",
        "move_in_black_delay_millis",
        "highlight_overrides"
      ]
    },
    "PatchFixtureRotation": {
      "description": "Stage rotation in degrees.",
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "format": "float"
        },
        "y": {
          "type": "number",
          "format": "float"
        },
        "z": {
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ]
    },
    "PatchHighlightOverrideProjection": {
      "type": "object",
      "properties": {
        "channel_id": {
          "type": "string",
          "format": "uuid"
        },
        "raw_value": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "channel_id",
        "raw_value"
      ]
    },
    "PatchLogicalHeadProjection": {
      "type": "object",
      "properties": {
        "fixture_id": {
          "type": "string",
          "format": "uuid"
        },
        "head_index": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "profile_head_id": {
          "description": "Stable semantic head identity from the selected immutable profile revision.",
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      },
      "required": [
        "profile_head_id",
        "head_index",
        "fixture_id"
      ]
    },
    "PatchModeProjection": {
      "type": "object",
      "properties": {
        "mode_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "splits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchModeSplitProjection"
          }
        }
      },
      "required": [
        "mode_id",
        "name",
        "splits"
      ]
    },
    "PatchModeSplitProjection": {
      "type": "object",
      "properties": {
        "footprint": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "split": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "split",
        "footprint"
      ]
    },
    "PatchMultiPatchProjection": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "location": {
          "$ref": "#/$defs/PatchFixtureLocation"
        },
        "name": {
          "type": "string"
        },
        "rotation": {
          "$ref": "#/$defs/PatchFixtureRotation"
        },
        "split_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchSplitAssignment"
          }
        }
      },
      "required": [
        "id",
        "name",
        "split_patches",
        "location",
        "rotation"
      ]
    },
    "PatchProfilePolicy": {
      "type": "string",
      "enum": [
        "dmx",
        "visual_only"
      ]
    },
    "PatchProfileRevisionProjection": {
      "description": "Deduplicated, Patch-only metadata for one immutable profile revision.",
      "type": "object",
      "properties": {
        "content_digest": {
          "type": "string"
        },
        "fixture_type": {
          "type": "string"
        },
        "manufacturer": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "patch_policy": {
          "$ref": "#/$defs/PatchProfilePolicy"
        },
        "profile_id": {
          "type": "string",
          "format": "uuid"
        },
        "profile_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "referenced_modes": {
          "description": "Only modes referenced by fixtures in the containing snapshot or delta, never the catalog.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatchModeProjection"
          },
          "minItems": 1
        }
      },
      "required": [
        "profile_id",
        "profile_revision",
        "content_digest",
        "manufacturer",
        "name",
        "fixture_type",
        "patch_policy",
        "referenced_modes"
      ]
    },
    "PatchSplitAssignment": {
      "type": "object",
      "properties": {
        "address": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "split": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "universe": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "split",
        "universe",
        "address"
      ]
    },
    "PlaybackCueTransition": {
      "type": "object",
      "properties": {
        "advanced_steps": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "cause": {
          "$ref": "#/$defs/PlaybackTransitionCause"
        },
        "cue_list_id": {
          "type": "string",
          "format": "uuid"
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "previous": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "playback_number",
        "cue_list_id",
        "previous",
        "current",
        "cause",
        "advanced_steps"
      ]
    },
    "PlaybackTransitionCause": {
      "type": "string",
      "enum": [
        "go",
        "back",
        "jump",
        "chaser",
        "follow",
        "wait",
        "timecode"
      ]
    },
    "SequenceGap": {
      "type": "object",
      "properties": {
        "after_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "latest_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "oldest_available": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "after_sequence",
        "oldest_available",
        "latest_sequence"
      ]
    },
    "ShowObjectChange": {
      "type": "object",
      "properties": {
        "body": true,
        "deleted": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/ShowObjectKind"
        },
        "object_id": {
          "type": "string"
        },
        "object_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "kind",
        "object_id",
        "object_revision",
        "body",
        "deleted"
      ]
    },
    "ShowObjectKind": {
      "type": "string",
      "enum": [
        "cue_list",
        "group",
        "playback",
        "playback_page",
        "preset"
      ]
    },
    "ShowObjectsChange": {
      "type": "object",
      "properties": {
        "changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ShowObjectChange"
          }
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision",
        "changes"
      ]
    }
  }
}
