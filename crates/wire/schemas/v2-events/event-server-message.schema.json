{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventServerMessage",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "cursor": {
          "$ref": "#/$defs/EventSnapshotCursor"
        },
        "type": {
          "type": "string",
          "const": "ready"
        }
      },
      "required": [
        "type",
        "cursor"
      ]
    },
    {
      "type": "object",
      "properties": {
        "event": {
          "$ref": "#/$defs/EventEnvelope"
        },
        "type": {
          "type": "string",
          "const": "event"
        }
      },
      "required": [
        "type",
        "event"
      ]
    },
    {
      "type": "object",
      "properties": {
        "gap": {
          "$ref": "#/$defs/SequenceGap"
        },
        "type": {
          "type": "string",
          "const": "gap"
        }
      },
      "required": [
        "type",
        "gap"
      ]
    },
    {
      "type": "object",
      "properties": {
        "cursor": {
          "$ref": "#/$defs/EventSnapshotCursor"
        },
        "type": {
          "type": "string",
          "const": "repaired"
        }
      },
      "required": [
        "type",
        "cursor"
      ]
    },
    {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "error"
        }
      },
      "required": [
        "type",
        "error"
      ]
    }
  ],
  "$defs": {
    "CueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "EventActionSource": {
      "type": "string",
      "enum": [
        "user_interface",
        "keyboard",
        "osc",
        "http",
        "midi",
        "matter",
        "cue",
        "timecode",
        "scheduler",
        "macro",
        "system"
      ]
    },
    "EventCapability": {
      "type": "string",
      "enum": [
        "programmer",
        "playback",
        "show",
        "desk",
        "output",
        "system"
      ]
    },
    "EventClass": {
      "type": "string",
      "enum": [
        "transition",
        "projection",
        "command_outcome",
        "error",
        "safety",
        "telemetry"
      ]
    },
    "EventDeliveryPolicy": {
      "type": "string",
      "enum": [
        "lossless",
        "replaceable"
      ]
    },
    "EventEnvelope": {
      "type": "object",
      "properties": {
        "class": {
          "$ref": "#/$defs/EventClass"
        },
        "correlation_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "delivery": {
          "$ref": "#/$defs/EventDeliveryPolicy"
        },
        "desk_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "object": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventObject"
            },
            {
              "type": "null"
            }
          ]
        },
        "occurred_at": {
          "type": "string"
        },
        "payload": {
          "$ref": "#/$defs/EventPayload"
        },
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "source": {
          "$ref": "#/$defs/EventSource"
        }
      },
      "required": [
        "sequence",
        "occurred_at",
        "desk_id",
        "class",
        "object",
        "source",
        "correlation_id",
        "delivery",
        "payload"
      ]
    },
    "EventObject": {
      "type": "object",
      "properties": {
        "capability": {
          "$ref": "#/$defs/EventCapability"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "capability",
        "id"
      ]
    },
    "EventPayload": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "transition": {
              "$ref": "#/$defs/PlaybackCueTransition"
            },
            "type": {
              "type": "string",
              "const": "playback_cue_transition"
            }
          },
          "required": [
            "type",
            "transition"
          ]
        }
      ]
    },
    "EventSnapshotCursor": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "sequence"
      ]
    },
    "EventSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "runtime"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "action"
            },
            "source": {
              "$ref": "#/$defs/EventActionSource"
            }
          },
          "required": [
            "kind",
            "source"
          ]
        }
      ]
    },
    "PlaybackCueTransition": {
      "type": "object",
      "properties": {
        "advanced_steps": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "cause": {
          "$ref": "#/$defs/PlaybackTransitionCause"
        },
        "cue_list_id": {
          "type": "string",
          "format": "uuid"
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "previous": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueReference"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "playback_number",
        "cue_list_id",
        "previous",
        "current",
        "cause",
        "advanced_steps"
      ]
    },
    "PlaybackTransitionCause": {
      "type": "string",
      "enum": [
        "go",
        "back",
        "jump",
        "chaser",
        "follow",
        "wait",
        "timecode"
      ]
    },
    "SequenceGap": {
      "type": "object",
      "properties": {
        "after_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "latest_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "oldest_available": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "after_sequence",
        "oldest_available",
        "latest_sequence"
      ]
    }
  }
}
