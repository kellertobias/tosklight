{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CueTransferOutcome",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "choice_id": {
          "type": "string",
          "format": "uuid"
        },
        "command_line": {
          "$ref": "#/$defs/CommandLineResponse"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "interaction_event_sequence": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "persistence_warning": {
          "type": [
            "string",
            "null"
          ]
        },
        "projections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CueTransferObjectProjection"
          }
        },
        "replayed": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "show_event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "const": "changed"
        },
        "summary": {
          "$ref": "#/$defs/CueTransferSummary"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "request_id",
        "correlation_id",
        "replayed",
        "show_id",
        "choice_id",
        "summary",
        "show_revision",
        "projections",
        "show_event_sequence",
        "command_line",
        "interaction_event_sequence",
        "persistence_warning"
      ]
    }
  ],
  "$defs": {
    "CommandChoiceOption": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/CommandChoiceOptionId"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "command"
      ]
    },
    "CommandChoiceOptionId": {
      "type": "string",
      "enum": [
        "plain",
        "status"
      ]
    },
    "CommandLineResponse": {
      "description": "One authoritative command-line projection and its optimistic-concurrency revision.",
      "type": "object",
      "properties": {
        "pending_choice": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueMoveCopyChoice"
            },
            {
              "type": "null"
            }
          ]
        },
        "pristine": {
          "type": "boolean"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "target": {
          "$ref": "#/$defs/CommandTarget"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "target",
        "pristine",
        "revision",
        "pending_choice"
      ]
    },
    "CommandTarget": {
      "description": "The desk-local default scope used when an operator starts a command.",
      "type": "string",
      "enum": [
        "FIXTURE",
        "GROUP"
      ]
    },
    "CueMoveCopyChoice": {
      "description": "Choice presented when Cue copy or move semantics would otherwise be ambiguous.",
      "type": "object",
      "properties": {
        "cancel_label": {
          "type": "string"
        },
        "choice_id": {
          "type": "string",
          "format": "uuid"
        },
        "command": {
          "type": "string"
        },
        "operation": {
          "$ref": "#/$defs/CueTransferOperation"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CommandChoiceOption"
          }
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "type": {
          "$ref": "#/$defs/CueMoveCopyChoiceType"
        }
      },
      "required": [
        "type",
        "choice_id",
        "show_id",
        "show_revision",
        "operation",
        "command",
        "options",
        "cancel_label"
      ]
    },
    "CueMoveCopyChoiceType": {
      "type": "string",
      "enum": [
        "cue_move_copy"
      ]
    },
    "CueTransferMode": {
      "type": "string",
      "enum": [
        "plain",
        "status"
      ]
    },
    "CueTransferObjectProjection": {
      "type": "object",
      "properties": {
        "body": true,
        "cue_list_id": {
          "type": "string",
          "format": "uuid"
        },
        "object_id": {
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "object_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "cue_list_id",
        "object_id",
        "object_revision",
        "body"
      ]
    },
    "CueTransferOperation": {
      "type": "string",
      "enum": [
        "copy",
        "move"
      ]
    },
    "CueTransferSummary": {
      "type": "object",
      "properties": {
        "destination_cue_id": {
          "type": "string",
          "format": "uuid"
        },
        "destination_cue_number": {
          "type": "number",
          "format": "double"
        },
        "mode": {
          "$ref": "#/$defs/CueTransferMode"
        },
        "operation": {
          "$ref": "#/$defs/CueTransferOperation"
        },
        "source_cue_id": {
          "type": "string",
          "format": "uuid"
        },
        "source_cue_number": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "operation",
        "mode",
        "source_cue_id",
        "source_cue_number",
        "destination_cue_id",
        "destination_cue_number"
      ]
    }
  }
}
