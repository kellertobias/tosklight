{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CueRecordOutcome",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "captured_source": {
          "$ref": "#/$defs/CueRecordCapturedSource"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "projections": {
          "$ref": "#/$defs/CueRecordProjections"
        },
        "recorded_cue": {
          "$ref": "#/$defs/RecordedCueProjection"
        },
        "replayed": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "runtime": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueRecordRuntimeOutcome"
            },
            {
              "type": "null"
            }
          ]
        },
        "show_event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "const": "changed"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "request_id",
        "correlation_id",
        "replayed",
        "captured_source",
        "show_revision",
        "recorded_cue",
        "projections",
        "show_event_sequence",
        "runtime"
      ]
    },
    {
      "type": "object",
      "properties": {
        "captured_source": {
          "$ref": "#/$defs/CueRecordCapturedSource"
        },
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "projections": {
          "$ref": "#/$defs/CueRecordProjections"
        },
        "recorded_cue": {
          "$ref": "#/$defs/RecordedCueProjection"
        },
        "replayed": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "const": "no_change"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "request_id",
        "correlation_id",
        "replayed",
        "captured_source",
        "show_revision",
        "recorded_cue",
        "projections"
      ]
    }
  ],
  "$defs": {
    "CueListRuntimeProjection": {
      "type": "object",
      "properties": {
        "activated_at": {
          "type": "string"
        },
        "cue_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next_is_loaded": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "fader_pickup_required": {
          "type": "boolean"
        },
        "fader_position": {
          "type": "number",
          "format": "float"
        },
        "flash": {
          "type": "boolean"
        },
        "loaded": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "manual_xfade_direction": {
          "$ref": "#/$defs/ManualXFadeDirection"
        },
        "manual_xfade_position": {
          "type": "number",
          "format": "float"
        },
        "manual_xfade_progress": {
          "type": "number",
          "format": "float"
        },
        "master": {
          "type": "number",
          "format": "float"
        },
        "normal_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "paused": {
          "type": "boolean"
        },
        "previous_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "swap_active": {
          "type": "boolean"
        },
        "temporary": {
          "type": "boolean"
        },
        "temporary_active": {
          "type": "boolean"
        },
        "temporary_master": {
          "type": "number",
          "format": "float"
        },
        "transition_timing_bypassed": {
          "type": "boolean"
        }
      },
      "required": [
        "cue_index",
        "previous_index",
        "current",
        "loaded",
        "normal_next",
        "effective_next",
        "effective_next_is_loaded",
        "paused",
        "activated_at",
        "master",
        "fader_position",
        "fader_pickup_required",
        "flash",
        "temporary",
        "temporary_active",
        "temporary_master",
        "swap_active",
        "enabled",
        "transition_timing_bypassed",
        "manual_xfade_position",
        "manual_xfade_direction",
        "manual_xfade_progress"
      ]
    },
    "CueRecordCapturedSource": {
      "type": "string",
      "enum": [
        "normal",
        "pending_preload",
        "active_preload"
      ]
    },
    "CueRecordProjections": {
      "type": "object",
      "properties": {
        "cue_list": {
          "$ref": "#/$defs/RecordedCueObjectProjection"
        },
        "page": {
          "anyOf": [
            {
              "$ref": "#/$defs/RecordedCueObjectProjection"
            },
            {
              "type": "null"
            }
          ]
        },
        "playback": {
          "anyOf": [
            {
              "$ref": "#/$defs/RecordedCueObjectProjection"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "cue_list",
        "playback",
        "page"
      ]
    },
    "CueRecordRuntimeOutcome": {
      "type": "object",
      "properties": {
        "event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "projection": {
          "$ref": "#/$defs/PlaybackRuntimeProjection"
        }
      },
      "additionalProperties": false,
      "required": [
        "projection",
        "event_sequence"
      ]
    },
    "GrandMasterRuntimeProjection": {
      "type": "object",
      "properties": {
        "blackout": {
          "type": "boolean"
        },
        "dynamics_paused": {
          "type": "boolean"
        },
        "effective_level": {
          "type": "number",
          "format": "float"
        },
        "flash_active": {
          "type": "boolean"
        },
        "level": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "level",
        "effective_level",
        "blackout",
        "flash_active",
        "dynamics_paused"
      ]
    },
    "ManualXFadeDirection": {
      "type": "string",
      "enum": [
        "towards_high",
        "towards_low"
      ]
    },
    "PlaybackCueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "PlaybackRuntimeIdentity": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "playback"
            },
            "playback_number": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "playback_number"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "cue_list_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string",
              "maxLength": 256,
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "const": "group"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "group_id"
          ]
        }
      ]
    },
    "PlaybackRuntimeProjection": {
      "type": "object",
      "properties": {
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "requested": {
          "$ref": "#/$defs/PlaybackRuntimeIdentity"
        },
        "scope": {
          "$ref": "#/$defs/PlaybackShowScope"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "const": "missing"
            }
          },
          "required": [
            "target"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "runtime": {
              "anyOf": [
                {
                  "$ref": "#/$defs/CueListRuntimeProjection"
                },
                {
                  "type": "null"
                }
              ]
            },
            "target": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "target",
            "cue_list_id",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "flash_level": {
              "type": "number",
              "format": "float"
            },
            "group_id": {
              "type": "string"
            },
            "master": {
              "type": "number",
              "format": "float"
            },
            "target": {
              "type": "string",
              "const": "group"
            }
          },
          "required": [
            "target",
            "group_id",
            "master",
            "flash_level"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group": {
              "type": "string"
            },
            "runtime": {
              "$ref": "#/$defs/SpeedGroupRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "speed_group"
            }
          },
          "required": [
            "target",
            "group",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "runtime": {
              "$ref": "#/$defs/GrandMasterRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "grand_master"
            }
          },
          "required": [
            "target",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "programmer_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "cue_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        }
      ],
      "required": [
        "scope",
        "requested",
        "playback_number"
      ]
    },
    "PlaybackShowScope": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision"
      ]
    },
    "RecordedCueObjectProjection": {
      "description": "One exact losslessly merged portable show object.",
      "type": "object",
      "properties": {
        "body": true,
        "id": {
          "type": "string"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "body"
      ]
    },
    "RecordedCueProjection": {
      "type": "object",
      "properties": {
        "deleted": {
          "type": "boolean"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "deleted"
      ]
    },
    "SoundLossReason": {
      "type": "string",
      "enum": [
        "source_unavailable",
        "no_usable_signal",
        "low_confidence",
        "tempo_outside_range",
        "waiting_for_analysis"
      ]
    },
    "SoundStatus": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "disabled"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "type": "object",
          "properties": {
            "confidence": {
              "type": "number",
              "format": "float"
            },
            "detected_bpm": {
              "type": "number",
              "format": "double"
            },
            "status": {
              "type": "string",
              "const": "active"
            }
          },
          "required": [
            "status",
            "detected_bpm",
            "confidence"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "remaining_millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "status": {
              "type": "string",
              "const": "holding"
            }
          },
          "required": [
            "status",
            "reason",
            "remaining_millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "status": {
              "type": "string",
              "const": "manual_fallback"
            }
          },
          "required": [
            "status",
            "reason"
          ]
        }
      ]
    },
    "SpeedGroupRuntimeProjection": {
      "type": "object",
      "properties": {
        "beat_phase": {
          "type": "number",
          "format": "double"
        },
        "effective_bpm": {
          "type": "number",
          "format": "double"
        },
        "input_level": {
          "type": "number",
          "format": "float"
        },
        "manual_bpm": {
          "type": "number",
          "format": "double"
        },
        "paused": {
          "type": "boolean"
        },
        "phase_advancing": {
          "type": "boolean"
        },
        "phase_origin_millis": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "selected_band_level": {
          "type": "number",
          "format": "float"
        },
        "sound_bpm": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "sound_multiplier": {
          "type": "number",
          "format": "double"
        },
        "sound_status": {
          "$ref": "#/$defs/SoundStatus"
        },
        "source": {
          "$ref": "#/$defs/SpeedSource"
        },
        "source_available": {
          "type": "boolean"
        },
        "speed_master_scale": {
          "type": "number",
          "format": "double"
        },
        "synchronized_with": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        },
        "usable_signal": {
          "type": "boolean"
        }
      },
      "required": [
        "manual_bpm",
        "sound_bpm",
        "effective_bpm",
        "source",
        "sound_status",
        "paused",
        "phase_advancing",
        "speed_master_scale",
        "sound_multiplier",
        "source_available",
        "usable_signal",
        "input_level",
        "selected_band_level",
        "synchronized_with",
        "phase_origin_millis",
        "beat_phase"
      ]
    },
    "SpeedSource": {
      "type": "string",
      "enum": [
        "manual",
        "sound",
        "held_sound",
        "manual_fallback"
      ]
    }
  }
}
