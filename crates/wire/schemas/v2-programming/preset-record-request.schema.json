{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PresetRecordRequest",
  "description": "Requests action-time capture; recordable Programmer values never cross the client boundary.",
  "type": "object",
  "properties": {
    "address": {
      "$ref": "#/$defs/PresetRecordingAddress"
    },
    "expected_object_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "mode": {
      "$ref": "#/$defs/PresetRecordingMode"
    },
    "name": {
      "type": "string",
      "maxLength": 256,
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "maxLength": 128,
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "required": [
    "request_id",
    "address",
    "name",
    "mode",
    "expected_object_revision"
  ],
  "$defs": {
    "PresetRecordingAddress": {
      "type": "object",
      "properties": {
        "family": {
          "$ref": "#/$defs/PresetRecordingFamily"
        },
        "number": {
          "type": "integer",
          "format": "uint32",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "family",
        "number"
      ]
    },
    "PresetRecordingFamily": {
      "type": "string",
      "enum": [
        "mixed",
        "intensity",
        "color",
        "position",
        "beam"
      ]
    },
    "PresetRecordingMode": {
      "type": "string",
      "enum": [
        "merge",
        "overwrite"
      ]
    }
  }
}
