{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgrammingLifecycleSnapshot",
  "type": "object",
  "properties": {
    "cursor": {
      "$ref": "#/$defs/EventSnapshotCursor"
    },
    "projection": {
      "$ref": "#/$defs/ProgrammingLifecycleProjection"
    }
  },
  "additionalProperties": false,
  "required": [
    "cursor",
    "projection"
  ],
  "$defs": {
    "EventSnapshotCursor": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "sequence"
      ]
    },
    "ProgrammingLifecycleProgrammer": {
      "type": "object",
      "properties": {
        "connected": {
          "type": "boolean"
        },
        "normal_value_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "preload_active": {
          "description": "Aggregate activity signal only; active Preload values and identities remain private.",
          "type": "boolean"
        },
        "programmer_id": {
          "type": "string",
          "format": "uuid"
        },
        "selected_fixture_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingLifecycleSession"
          }
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false,
      "required": [
        "programmer_id",
        "user_id",
        "connected",
        "selected_fixture_count",
        "normal_value_count",
        "preload_active",
        "sessions"
      ]
    },
    "ProgrammingLifecycleProjection": {
      "type": "object",
      "properties": {
        "programmers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingLifecycleProgrammer"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "revision",
        "programmers"
      ]
    },
    "ProgrammingLifecycleSession": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false,
      "required": [
        "session_id"
      ]
    }
  }
}
