{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PresetRecallOutcome",
  "type": "object",
  "properties": {
    "active_context": {
      "type": "string"
    },
    "applied_fixtures": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "capture_mode_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "interaction_event_sequence": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "preset": {
      "$ref": "#/$defs/RecalledPresetProjection"
    },
    "programmer_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "replayed": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "selection_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "show_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "warning": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "event_sequence": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "projection": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProgrammingValuesProjection"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "const": "changed"
        }
      },
      "required": [
        "status"
      ]
    },
    {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "const": "no_change"
        }
      },
      "required": [
        "status"
      ]
    }
  ],
  "required": [
    "request_id",
    "correlation_id",
    "replayed",
    "show_revision",
    "programmer_revision",
    "capture_mode_revision",
    "selection_revision",
    "applied_fixtures",
    "active_context",
    "preset"
  ],
  "$defs": {
    "ProgrammingAttributeValue": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "normalized"
            },
            "value": {
              "type": "number",
              "format": "float"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "spread"
            },
            "value": {
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "discrete"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "color_xyz"
            },
            "value": {
              "$ref": "#/$defs/ProgrammingColorXyz"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "raw_dmx"
            },
            "value": {
              "type": "integer",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "raw_dmx_exact"
            },
            "value": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "value"
          ]
        }
      ]
    },
    "ProgrammingColorXyz": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "format": "float"
        },
        "y": {
          "type": "number",
          "format": "float"
        },
        "z": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ]
    },
    "ProgrammingFixtureValue": {
      "type": "object",
      "properties": {
        "attribute": {
          "type": "string"
        },
        "delay_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fade": {
          "type": "boolean"
        },
        "fade_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fixture_id": {
          "type": "string",
          "format": "uuid"
        },
        "programmer_order": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "value": {
          "$ref": "#/$defs/ProgrammingAttributeValue"
        }
      },
      "required": [
        "fixture_id",
        "attribute",
        "value",
        "programmer_order",
        "fade"
      ]
    },
    "ProgrammingGroupValue": {
      "type": "object",
      "properties": {
        "attribute": {
          "type": "string"
        },
        "delay_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fade": {
          "type": "boolean"
        },
        "fade_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "group_id": {
          "type": "string"
        },
        "programmer_order": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "value": {
          "$ref": "#/$defs/ProgrammingAttributeValue"
        }
      },
      "required": [
        "group_id",
        "attribute",
        "value",
        "programmer_order",
        "fade"
      ]
    },
    "ProgrammingValuesProjection": {
      "description": "Full retained projection of one user's normal, recordable Programmer values.",
      "type": "object",
      "properties": {
        "fixture_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingFixtureValue"
          }
        },
        "group_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingGroupValue"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "user_id",
        "revision",
        "fixture_values",
        "group_values"
      ]
    },
    "RecalledPresetProjection": {
      "type": "object",
      "properties": {
        "body": true,
        "id": {
          "type": "string"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "body"
      ]
    }
  }
}
