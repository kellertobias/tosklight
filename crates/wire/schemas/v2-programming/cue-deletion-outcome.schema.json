    {
      "type": "object",
      "properties": {
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "cue_list": {
          "$ref": "#/$defs/CueDeletionObjectProjection"
        },
        "deleted_cue": {
          "$ref": "#/$defs/DeletedCueProjection"
        },
        "persistence_warning": {
          "type": [
            "string",
            "null"
          ]
        },
        "replayed": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
