{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgrammingUpdateActionOutcome",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "correlation_id": {
          "type": "string",
          "format": "uuid"
        },
        "event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "projection": {
          "$ref": "#/$defs/ProgrammingUpdateProjection"
        },
        "replayed": {
          "type": "boolean"
        },
        "request_id": {
          "type": "string"
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "const": "changed"
        },
        "summary": {
          "$ref": "#/$defs/ProgrammingUpdateSummary"
        }
      },
      "additionalProperties": false,
      "required": [
        "status",
        "request_id",
        "correlation_id",
        "replayed",
        "show_id",
        "show_revision",
        "projection",
        "event_sequence",
        "summary"
      ]
    }
  ],
  "$defs": {
    "ProgrammingUpdateCueIdentity": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "number"
      ]
    },
    "ProgrammingUpdateCueSource": {
      "type": "object",
      "properties": {
        "cue_id": {
          "type": "string",
          "format": "uuid"
        },
        "cue_index": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "cue_number": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": false,
      "required": [
        "cue_id",
        "cue_number",
        "cue_index"
      ]
    },
    "ProgrammingUpdateObjectKind": {
      "type": "string",
      "enum": [
        "cue_list",
        "preset",
        "group"
      ]
    },
    "ProgrammingUpdateProjection": {
      "type": "object",
      "properties": {
        "body": true,
        "kind": {
          "$ref": "#/$defs/ProgrammingUpdateObjectKind"
        },
        "object_id": {
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "object_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "kind",
        "object_id",
        "object_revision",
        "body"
      ]
    },
    "ProgrammingUpdateSummary": {
      "type": "object",
      "properties": {
        "added_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "changed_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "changed_cues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingUpdateCueSource"
          }
        },
        "eligible_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "ignored_count": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "programmer_values_retained": {
          "type": "boolean"
        },
        "revision_after": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "revision_before": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "target": {
          "$ref": "#/$defs/ProgrammingUpdateTargetIdentity"
        }
      },
      "additionalProperties": false,
      "required": [
        "target",
        "revision_before",
        "revision_after",
        "eligible_count",
        "changed_count",
        "added_count",
        "ignored_count",
        "changed_cues",
        "programmer_values_retained"
      ]
    },
    "ProgrammingUpdateTargetFamily": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "cue"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "preset"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "group"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        }
      ]
    },
    "ProgrammingUpdateTargetIdentity": {
      "type": "object",
      "properties": {
        "cue": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProgrammingUpdateCueIdentity"
            },
            {
              "type": "null"
            }
          ]
        },
        "family": {
          "$ref": "#/$defs/ProgrammingUpdateTargetFamily"
        },
        "name": {
          "type": "string"
        },
        "object_id": {
          "type": "string",
          "maxLength": 256,
          "minLength": 1
        },
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "family",
        "object_id",
        "name"
      ]
    }
  }
}
