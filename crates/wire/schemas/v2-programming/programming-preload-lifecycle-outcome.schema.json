{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgrammingPreloadLifecycleOutcome",
  "type": "object",
  "properties": {
    "active": {
      "description": "True only while retained active Preload fixture or Group values exist. Armed capture is\nrepresented independently by `capture_mode.blind`.",
      "type": "boolean"
    },
    "capture_mode": {
      "$ref": "#/$defs/ProgrammingCaptureModeProjection"
    },
    "capture_mode_event_sequence": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "commit": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProgrammingPreloadCommitOutcome"
        },
        {
          "type": "null"
        }
      ]
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "interaction_event_sequence": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "queue_event_sequence": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "queue_projection": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProgrammingPreloadPlaybackQueueProjection"
        },
        {
          "type": "null"
        }
      ]
    },
    "queue_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "replayed": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "selection_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "status": {
      "$ref": "#/$defs/ProgrammingPreloadLifecycleState"
    },
    "values_event_sequence": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "values_projection": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProgrammingPreloadValuesProjection"
        },
        {
          "type": "null"
        }
      ]
    },
    "values_revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "warning": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "request_id",
    "correlation_id",
    "replayed",
    "status",
    "active",
    "capture_mode",
    "values_revision",
    "queue_revision",
    "selection_revision"
  ],
  "$defs": {
    "CueListRuntimeProjection": {
      "type": "object",
      "properties": {
        "activated_at": {
          "type": "string"
        },
        "cue_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next_is_loaded": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "fader_pickup_required": {
          "type": "boolean"
        },
        "fader_position": {
          "type": "number",
          "format": "float"
        },
        "flash": {
          "type": "boolean"
        },
        "loaded": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "manual_xfade_direction": {
          "$ref": "#/$defs/ManualXFadeDirection"
        },
        "manual_xfade_position": {
          "type": "number",
          "format": "float"
        },
        "manual_xfade_progress": {
          "type": "number",
          "format": "float"
        },
        "master": {
          "type": "number",
          "format": "float"
        },
        "normal_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "paused": {
          "type": "boolean"
        },
        "previous_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "swap_active": {
          "type": "boolean"
        },
        "temporary": {
          "type": "boolean"
        },
        "temporary_active": {
          "type": "boolean"
        },
        "temporary_master": {
          "type": "number",
          "format": "float"
        },
        "transition_timing_bypassed": {
          "type": "boolean"
        }
      },
      "required": [
        "cue_index",
        "previous_index",
        "current",
        "loaded",
        "normal_next",
        "effective_next",
        "effective_next_is_loaded",
        "paused",
        "activated_at",
        "master",
        "fader_position",
        "fader_pickup_required",
        "flash",
        "temporary",
        "temporary_active",
        "temporary_master",
        "swap_active",
        "enabled",
        "transition_timing_bypassed",
        "manual_xfade_position",
        "manual_xfade_direction",
        "manual_xfade_progress"
      ]
    },
    "GrandMasterRuntimeProjection": {
      "type": "object",
      "properties": {
        "blackout": {
          "type": "boolean"
        },
        "dynamics_paused": {
          "type": "boolean"
        },
        "effective_level": {
          "type": "number",
          "format": "float"
        },
        "flash_active": {
          "type": "boolean"
        },
        "level": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "level",
        "effective_level",
        "blackout",
        "flash_active",
        "dynamics_paused"
      ]
    },
    "ManualXFadeDirection": {
      "type": "string",
      "enum": [
        "towards_high",
        "towards_low"
      ]
    },
    "PlaybackCueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "PlaybackRuntimeIdentity": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "playback"
            },
            "playback_number": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "playback_number"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "cue_list_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string",
              "maxLength": 256,
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "const": "group"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "group_id"
          ]
        }
      ]
    },
    "PlaybackRuntimeProjection": {
      "type": "object",
      "properties": {
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "requested": {
          "$ref": "#/$defs/PlaybackRuntimeIdentity"
        },
        "scope": {
          "$ref": "#/$defs/PlaybackShowScope"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "const": "missing"
            }
          },
          "required": [
            "target"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "runtime": {
              "anyOf": [
                {
                  "$ref": "#/$defs/CueListRuntimeProjection"
                },
                {
                  "type": "null"
                }
              ]
            },
            "target": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "target",
            "cue_list_id",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "flash_level": {
              "type": "number",
              "format": "float"
            },
            "group_id": {
              "type": "string"
            },
            "master": {
              "type": "number",
              "format": "float"
            },
            "target": {
              "type": "string",
              "const": "group"
            }
          },
          "required": [
            "target",
            "group_id",
            "master",
            "flash_level"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group": {
              "type": "string"
            },
            "runtime": {
              "$ref": "#/$defs/SpeedGroupRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "speed_group"
            }
          },
          "required": [
            "target",
            "group",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "runtime": {
              "$ref": "#/$defs/GrandMasterRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "grand_master"
            }
          },
          "required": [
            "target",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "programmer_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "cue_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        }
      ],
      "required": [
        "scope",
        "requested",
        "playback_number"
      ]
    },
    "PlaybackShowScope": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision"
      ]
    },
    "ProgrammingCaptureModeProjection": {
      "description": "Authoritative capture routing for one user's Programmer.",
      "type": "object",
      "properties": {
        "blind": {
          "type": "boolean"
        },
        "preload_capture_programmer": {
          "type": "boolean"
        },
        "preview": {
          "type": "boolean"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false,
      "required": [
        "user_id",
        "revision",
        "blind",
        "preview",
        "preload_capture_programmer"
      ]
    },
    "ProgrammingPreloadAttributeValue": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "normalized"
            },
            "value": {
              "type": "number",
              "format": "float"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "spread"
            },
            "value": {
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "discrete"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "color_xyz"
            },
            "value": {
              "$ref": "#/$defs/ProgrammingPreloadColorXyz"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "raw_dmx"
            },
            "value": {
              "type": "integer",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "raw_dmx_exact"
            },
            "value": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        }
      ]
    },
    "ProgrammingPreloadColorXyz": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "format": "float"
        },
        "y": {
          "type": "number",
          "format": "float"
        },
        "z": {
          "type": "number",
          "format": "float"
        }
      },
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ]
    },
    "ProgrammingPreloadCommitOutcome": {
      "type": "object",
      "properties": {
        "committed_at": {
          "type": "string"
        },
        "executed": {
          "description": "Ordered actions consumed by this one atomic commit. Runtime changes remain separately\ndeduplicated by authoritative Playback identity below.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingPreloadPlaybackQueueItem"
          }
        },
        "executed_playback_actions": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "playback_event_sequence_after": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "playback_event_sequence_before": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "programmer_fade_millis": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "runtime_changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingPreloadRuntimeOutcome"
          }
        },
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "show_id",
        "show_revision",
        "playback_event_sequence_before",
        "playback_event_sequence_after",
        "committed_at",
        "programmer_fade_millis",
        "executed_playback_actions",
        "executed",
        "runtime_changes"
      ]
    },
    "ProgrammingPreloadFixtureValue": {
      "type": "object",
      "properties": {
        "attribute": {
          "type": "string"
        },
        "delay_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fade": {
          "type": "boolean"
        },
        "fade_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fixture_id": {
          "type": "string",
          "format": "uuid"
        },
        "programmer_order": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "value": {
          "$ref": "#/$defs/ProgrammingPreloadAttributeValue"
        }
      },
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "attribute",
        "value",
        "programmer_order",
        "fade"
      ]
    },
    "ProgrammingPreloadGroupValue": {
      "type": "object",
      "properties": {
        "attribute": {
          "type": "string"
        },
        "delay_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "fade": {
          "type": "boolean"
        },
        "fade_millis": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "group_id": {
          "type": "string"
        },
        "programmer_order": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "value": {
          "$ref": "#/$defs/ProgrammingPreloadAttributeValue"
        }
      },
      "additionalProperties": false,
      "required": [
        "group_id",
        "attribute",
        "value",
        "programmer_order",
        "fade"
      ]
    },
    "ProgrammingPreloadLifecycleState": {
      "type": "string",
      "enum": [
        "changed",
        "no_change"
      ]
    },
    "ProgrammingPreloadPlaybackAction": {
      "type": "string",
      "enum": [
        "toggle",
        "go",
        "back",
        "off",
        "on",
        "temporary_on",
        "temporary_off"
      ]
    },
    "ProgrammingPreloadPlaybackQueueItem": {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/ProgrammingPreloadPlaybackAction"
        },
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        },
        "playback_number": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "surface": {
          "$ref": "#/$defs/ProgrammingPreloadPlaybackSurface"
        }
      },
      "required": [
        "playback_number",
        "action",
        "surface"
      ]
    },
    "ProgrammingPreloadPlaybackQueueProjection": {
      "type": "object",
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingPreloadPlaybackQueueItem"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "user_id",
        "revision",
        "actions"
      ]
    },
    "ProgrammingPreloadPlaybackSurface": {
      "type": "string",
      "enum": [
        "physical",
        "virtual",
        "osc",
        "matter"
      ]
    },
    "ProgrammingPreloadRuntimeOutcome": {
      "type": "object",
      "properties": {
        "event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "projection": {
          "$ref": "#/$defs/PlaybackRuntimeProjection"
        }
      },
      "additionalProperties": false,
      "required": [
        "projection",
        "event_sequence"
      ]
    },
    "ProgrammingPreloadValuesProjection": {
      "type": "object",
      "properties": {
        "fixture_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingPreloadFixtureValue"
          }
        },
        "group_values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProgrammingPreloadGroupValue"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "user_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false,
      "required": [
        "user_id",
        "revision",
        "fixture_values",
        "group_values"
      ]
    },
    "SoundLossReason": {
      "type": "string",
      "enum": [
        "source_unavailable",
        "no_usable_signal",
        "low_confidence",
        "tempo_outside_range",
        "waiting_for_analysis"
      ]
    },
    "SoundStatus": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "disabled"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "type": "object",
          "properties": {
            "confidence": {
              "type": "number",
              "format": "float"
            },
            "detected_bpm": {
              "type": "number",
              "format": "double"
            },
            "status": {
              "type": "string",
              "const": "active"
            }
          },
          "required": [
            "status",
            "detected_bpm",
            "confidence"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "remaining_millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "status": {
              "type": "string",
              "const": "holding"
            }
          },
          "required": [
            "status",
            "reason",
            "remaining_millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "status": {
              "type": "string",
              "const": "manual_fallback"
            }
          },
          "required": [
            "status",
            "reason"
          ]
        }
      ]
    },
    "SpeedGroupRuntimeProjection": {
      "type": "object",
      "properties": {
        "beat_phase": {
          "type": "number",
          "format": "double"
        },
        "effective_bpm": {
          "type": "number",
          "format": "double"
        },
