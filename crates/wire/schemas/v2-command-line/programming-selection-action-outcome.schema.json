{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProgrammingSelectionActionOutcome",
  "type": "object",
  "properties": {
    "action": {
      "$ref": "#/$defs/ProgrammingSelectionAcceptedAction"
    },
    "applied": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_sequence": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "replayed": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "selection": {
      "$ref": "#/$defs/ProgrammerSelectionProjection"
    },
    "warning": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "request_id",
    "correlation_id",
    "action",
    "applied",
    "selection",
    "event_sequence",
    "replayed"
  ],
  "$defs": {
    "ProgrammerSelectionExpression": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "static"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string"
            },
            "rule": {
              "$ref": "#/$defs/ProgrammerSelectionRule"
            },
            "type": {
              "type": "string",
              "const": "live_group"
            }
          },
          "required": [
            "type",
            "group_id",
            "rule"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string"
            },
            "source_revision": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "frozen_group"
            }
          },
          "required": [
            "type",
            "group_id",
            "source_revision"
          ]
        },
        {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ProgrammerSelectionReference"
              }
            },
            "type": {
              "type": "string",
              "const": "playback_contents"
            }
          },
          "required": [
            "type",
            "items"
          ]
        },
        {
          "type": "object",
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ProgrammerSelectionReference"
              }
            },
            "type": {
              "type": "string",
              "const": "sources"
            }
          },
          "required": [
            "type",
            "items"
          ]
        }
      ]
    },
    "ProgrammerSelectionProjection": {
      "description": "Ordered desk-local selection and the operation revision which produced it.",
      "type": "object",
      "properties": {
        "expression": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProgrammerSelectionExpression"
            },
            {
              "type": "null"
            }
          ]
        },
        "gesture_open": {
          "type": "boolean"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "selected": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "required": [
        "selected",
        "expression",
        "revision",
        "gesture_open"
      ]
    },
    "ProgrammerSelectionReference": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "fixture_id": {
              "type": "string",
              "format": "uuid"
            },
            "type": {
              "type": "string",
              "const": "fixture"
            }
          },
          "required": [
            "type",
            "fixture_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "live_group"
            }
          },
          "required": [
            "type",
            "group_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "fixture_id": {
              "type": "string",
              "format": "uuid"
            },
            "type": {
              "type": "string",
              "const": "remove_fixture"
            }
          },
          "required": [
            "type",
            "fixture_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group_id": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "remove_live_group"
            }
          },
          "required": [
            "type",
            "group_id"
          ]
        }
      ]
    },
    "ProgrammerSelectionRule": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "all"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "odd"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "even"
            }
          },
          "additionalProperties": false,
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "n": {
              "type": "integer",
              "format": "uint64",
              "maximum": 9007199254740991,
              "minimum": 1
            },
            "offset": {
              "type": "integer",
              "format": "uint64",
              "maximum": 9007199254740991,
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "every_nth"
            }
          },
          "additionalProperties": false,
          "required": [
            "type",
            "n",
            "offset"
          ]
        }
      ]
    },
    "ProgrammingSelectionAcceptedAction": {
      "type": "string",
      "enum": [
        "replaced",
        "gesture_applied",
        "group_selected",
        "rule_applied"
      ]
    }
  }
}
