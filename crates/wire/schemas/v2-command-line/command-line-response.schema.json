{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandLineResponse",
  "description": "One authoritative command-line projection and its optimistic-concurrency revision.",
  "type": "object",
  "properties": {
    "pending_choice": {
      "anyOf": [
        {
          "$ref": "#/$defs/CueMoveCopyChoice"
        },
        {
          "type": "null"
        }
      ]
    },
    "pristine": {
      "type": "boolean"
    },
    "revision": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "target": {
      "$ref": "#/$defs/CommandTarget"
    },
    "text": {
      "type": "string"
    }
  },
  "required": [
    "text",
    "target",
    "pristine",
    "revision",
    "pending_choice"
  ],
  "$defs": {
    "CommandChoiceOption": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/CommandChoiceOptionId"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "command"
      ]
    },
    "CommandChoiceOptionId": {
      "type": "string",
      "enum": [
        "plain",
        "status"
      ]
    },
    "CommandTarget": {
      "description": "The desk-local default scope used when an operator starts a command.",
      "type": "string",
      "enum": [
        "FIXTURE",
        "GROUP"
      ]
    },
    "CueMoveCopyChoice": {
      "description": "Choice presented when Cue copy or move semantics would otherwise be ambiguous.",
      "type": "object",
      "properties": {
        "cancel_label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "operation": {
          "$ref": "#/$defs/CueTransferOperation"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CommandChoiceOption"
          }
        },
        "type": {
          "$ref": "#/$defs/CueMoveCopyChoiceType"
        }
      },
      "required": [
        "type",
        "operation",
        "command",
        "options",
        "cancel_label"
      ]
    },
    "CueMoveCopyChoiceType": {
      "type": "string",
      "enum": [
        "cue_move_copy"
      ]
    },
    "CueTransferOperation": {
      "type": "string",
      "enum": [
        "copy",
        "move"
      ]
    }
  }
}
