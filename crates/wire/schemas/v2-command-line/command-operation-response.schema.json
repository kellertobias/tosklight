{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandOperationResponse",
  "description": "Complete response to a mutating command-line operation.",
  "type": "object",
  "properties": {
    "command_line": {
      "$ref": "#/$defs/CommandLineResponse"
    },
    "request_id": {
      "type": "string"
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "action": {
          "$ref": "#/$defs/CommandAcceptedAction"
        },
        "applied": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "outcome": {
          "type": "string",
          "const": "accepted"
        },
        "warning": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "outcome",
        "action"
      ]
    },
    {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "const": "choice_required"
        },
        "pending_choice": {
          "$ref": "#/$defs/CueMoveCopyChoice"
        }
      },
      "required": [
        "outcome",
        "pending_choice"
      ]
    },
    {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        },
        "outcome": {
          "type": "string",
          "const": "rejected"
        }
      },
      "required": [
        "outcome",
        "error"
      ]
    }
  ],
  "required": [
    "request_id",
    "command_line"
  ],
  "$defs": {
    "CommandAcceptedAction": {
      "description": "Accepted command-line state transition.",
      "type": "string",
      "enum": [
        "edited",
        "executed",
        "cleared_command_line",
        "cleared_preload",
        "cleared_selection",
        "cleared_values",
        "undone",
        "no_change",
        "preload_entered",
        "preload_committed",
        "shift_pressed",
        "shift_released",
        "ignored_release"
      ]
    },
    "CommandChoiceOption": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "id": {
          "$ref": "#/$defs/CommandChoiceOptionId"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "label",
        "command"
      ]
    },
    "CommandChoiceOptionId": {
      "type": "string",
      "enum": [
        "plain",
        "status"
      ]
    },
    "CommandLineResponse": {
      "description": "One authoritative command-line projection and its optimistic-concurrency revision.",
      "type": "object",
      "properties": {
        "pending_choice": {
          "anyOf": [
            {
              "$ref": "#/$defs/CueMoveCopyChoice"
            },
            {
              "type": "null"
            }
          ]
        },
        "pristine": {
          "type": "boolean"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "target": {
          "$ref": "#/$defs/CommandTarget"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "target",
        "pristine",
        "revision",
        "pending_choice"
      ]
    },
    "CommandTarget": {
      "description": "The desk-local default scope used when an operator starts a command.",
      "type": "string",
      "enum": [
        "FIXTURE",
        "GROUP"
      ]
    },
    "CueMoveCopyChoice": {
      "description": "Choice presented when Cue copy or move semantics would otherwise be ambiguous.",
      "type": "object",
      "properties": {
        "cancel_label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "operation": {
          "$ref": "#/$defs/CueTransferOperation"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CommandChoiceOption"
          }
        },
        "type": {
          "$ref": "#/$defs/CueMoveCopyChoiceType"
        }
      },
      "required": [
        "type",
        "operation",
        "command",
        "options",
        "cancel_label"
      ]
    },
    "CueMoveCopyChoiceType": {
      "type": "string",
      "enum": [
        "cue_move_copy"
      ]
    },
    "CueTransferOperation": {
      "type": "string",
      "enum": [
        "copy",
        "move"
      ]
    }
  }
}
