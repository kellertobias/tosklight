{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OutputRuntimeActionOutcome",
  "type": "object",
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "durability": {
      "$ref": "#/$defs/OutputRuntimeDurability"
    },
    "projection": {
      "$ref": "#/$defs/OutputRuntimeProjection"
    },
    "replayed": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "warning": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "event_sequence": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "const": "changed"
        }
      },
      "required": [
        "status",
        "event_sequence"
      ]
    },
    {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "const": "no_change"
        }
      },
      "required": [
        "status"
      ]
    }
  ],
  "required": [
    "request_id",
    "correlation_id",
    "projection",
    "replayed",
    "durability"
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "OutputRuntimeDurability": {
      "type": "string",
      "enum": [
        "durable",
        "persistence_pending"
      ]
    },
    "OutputRuntimeIdentity": {
      "type": "string",
      "enum": [
        "global_master"
      ]
    },
    "OutputRuntimeProjection": {
      "type": "object",
      "properties": {
        "blackout": {
          "type": "boolean"
        },
        "grand_master": {
          "type": "number",
          "format": "float"
        },
        "identity": {
          "$ref": "#/$defs/OutputRuntimeIdentity"
        },
        "revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "scope": {
          "$ref": "#/$defs/OutputRuntimeScope"
        }
      },
      "additionalProperties": false,
      "required": [
        "scope",
        "identity",
        "revision",
        "grand_master",
        "blackout"
      ]
    },
    "OutputRuntimeScope": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false,
      "required": [
        "show_id"
      ]
    }
  }
}
