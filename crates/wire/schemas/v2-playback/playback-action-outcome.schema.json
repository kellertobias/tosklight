{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlaybackActionOutcome",
  "type": "object",
  "properties": {
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "desk": {
      "anyOf": [
        {
          "$ref": "#/$defs/PlaybackDeskProjection"
        },
        {
          "type": "null"
        }
      ]
    },
    "desk_event_sequence": {
      "description": "Sequence of a separate desk-local view event when selection changed.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "durability": {
      "$ref": "#/$defs/PlaybackDurability"
    },
    "event_sequence": {
      "description": "Exact sequence of the emitted semantic event; absent for no-change or captured actions.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint64",
      "minimum": 0
    },
    "outcome": {
      "$ref": "#/$defs/PlaybackOutcome"
    },
    "projection": {
      "$ref": "#/$defs/PlaybackRuntimeProjection"
    },
    "replayed": {
      "type": "boolean"
    },
    "request_id": {
      "type": "string"
    },
    "requested": {
      "$ref": "#/$defs/PlaybackAddress"
    },
    "resolved": {
      "$ref": "#/$defs/ResolvedPlaybackAddress"
    }
  },
  "required": [
    "request_id",
    "correlation_id",
    "requested",
    "resolved",
    "outcome",
    "durability",
    "projection",
    "desk",
    "event_sequence",
    "desk_event_sequence",
    "replayed"
  ],
  "$defs": {
    "CueListRuntimeProjection": {
      "type": "object",
      "properties": {
        "activated_at": {
          "type": "string"
        },
        "cue_index": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "current": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "effective_next_is_loaded": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "fader_pickup_required": {
          "type": "boolean"
        },
        "fader_position": {
          "type": "number",
          "format": "float"
        },
        "flash": {
          "type": "boolean"
        },
        "loaded": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "manual_xfade_direction": {
          "$ref": "#/$defs/ManualXFadeDirection"
        },
        "manual_xfade_position": {
          "type": "number",
          "format": "float"
        },
        "manual_xfade_progress": {
          "type": "number",
          "format": "float"
        },
        "master": {
          "type": "number",
          "format": "float"
        },
        "normal_next": {
          "anyOf": [
            {
              "$ref": "#/$defs/PlaybackCueReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "paused": {
          "type": "boolean"
        },
        "previous_index": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "swap_active": {
          "type": "boolean"
        },
        "temporary": {
          "type": "boolean"
        },
        "temporary_active": {
          "type": "boolean"
        },
        "temporary_master": {
          "type": "number",
          "format": "float"
        },
        "transition_timing_bypassed": {
          "type": "boolean"
        }
      },
      "required": [
        "cue_index",
        "previous_index",
        "current",
        "loaded",
        "normal_next",
        "effective_next",
        "effective_next_is_loaded",
        "paused",
        "activated_at",
        "master",
        "fader_position",
        "fader_pickup_required",
        "flash",
        "temporary",
        "temporary_active",
        "temporary_master",
        "swap_active",
        "enabled",
        "transition_timing_bypassed",
        "manual_xfade_position",
        "manual_xfade_direction",
        "manual_xfade_progress"
      ]
    },
    "GrandMasterRuntimeProjection": {
      "type": "object",
      "properties": {
        "blackout": {
          "type": "boolean"
        },
        "dynamics_paused": {
          "type": "boolean"
        },
        "effective_level": {
          "type": "number",
          "format": "float"
        },
        "flash_active": {
          "type": "boolean"
        },
        "level": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "level",
        "effective_level",
        "blackout",
        "flash_active",
        "dynamics_paused"
      ]
    },
    "ManualXFadeDirection": {
      "type": "string",
      "enum": [
        "towards_high",
        "towards_low"
      ]
    },
    "PendingPlaybackAction": {
      "type": "string",
      "enum": [
        "toggle",
        "go",
        "back",
        "off",
        "on",
        "temporary_on",
        "temporary_off"
      ]
    },
    "PlaybackAddress": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "kind",
            "cue_list_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "playback"
            },
            "playback_number": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "playback_number"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "current_page"
            },
            "slot": {
              "type": "integer",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "slot"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "explicit_page"
            },
            "page": {
              "type": "integer",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            },
            "slot": {
              "type": "integer",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "page",
            "slot"
          ]
        }
      ]
    },
    "PlaybackCueReference": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "number": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "id",
        "number"
      ]
    },
    "PlaybackDeskProjection": {
      "type": "object",
      "properties": {
        "active_page": {
          "type": "integer",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        },
        "desk_id": {
          "type": "string",
          "format": "uuid"
        },
        "scope": {
          "$ref": "#/$defs/PlaybackShowScope"
        },
        "selected_playback": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "scope",
        "desk_id",
        "active_page",
        "selected_playback"
      ]
    },
    "PlaybackDurability": {
      "type": "string",
      "enum": [
        "durable",
        "persistence_pending"
      ]
    },
    "PlaybackOutcome": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "applied"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "no_change"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "type": "object",
          "properties": {
            "pending": {
              "$ref": "#/$defs/PendingPlaybackAction"
            },
            "status": {
              "type": "string",
              "const": "captured"
            }
          },
          "required": [
            "status",
            "pending"
          ]
        }
      ]
    },
    "PlaybackRuntimeIdentity": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "playback"
            },
            "playback_number": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "playback_number"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "kind",
            "cue_list_id"
          ]
        }
      ]
    },
    "PlaybackRuntimeProjection": {
      "type": "object",
      "properties": {
        "playback_number": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "requested": {
          "$ref": "#/$defs/PlaybackRuntimeIdentity"
        },
        "scope": {
          "$ref": "#/$defs/PlaybackShowScope"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "target": {
              "type": "string",
              "const": "missing"
            }
          },
          "required": [
            "target"
          ]
        },
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "runtime": {
              "anyOf": [
                {
                  "$ref": "#/$defs/CueListRuntimeProjection"
                },
                {
                  "type": "null"
                }
              ]
            },
            "target": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "target",
            "cue_list_id",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "flash_level": {
              "type": "number",
              "format": "float"
            },
            "group_id": {
              "type": "string"
            },
            "master": {
              "type": "number",
              "format": "float"
            },
            "target": {
              "type": "string",
              "const": "group"
            }
          },
          "required": [
            "target",
            "group_id",
            "master",
            "flash_level"
          ]
        },
        {
          "type": "object",
          "properties": {
            "group": {
              "type": "string"
            },
            "runtime": {
              "$ref": "#/$defs/SpeedGroupRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "speed_group"
            }
          },
          "required": [
            "target",
            "group",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "runtime": {
              "$ref": "#/$defs/GrandMasterRuntimeProjection"
            },
            "target": {
              "type": "string",
              "const": "grand_master"
            }
          },
          "required": [
            "target",
            "runtime"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "programmer_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "target": {
              "type": "string",
              "const": "cue_fade"
            }
          },
          "required": [
            "target",
            "millis"
          ]
        }
      ],
      "required": [
        "scope",
        "requested",
        "playback_number"
      ]
    },
    "PlaybackShowScope": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "string",
          "format": "uuid"
        },
        "show_revision": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "show_id",
        "show_revision"
      ]
    },
    "ResolvedPlaybackAddress": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "cue_list_id": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "const": "cue_list"
            }
          },
          "required": [
            "kind",
            "cue_list_id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "playback"
            },
            "page": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            },
            "playback_number": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            },
            "slot": {
              "type": [
                "integer",
                "null"
              ],
              "format": "uint8",
              "maximum": 255,
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "playback_number",
            "page",
            "slot"
          ]
        }
      ]
    },
    "SoundLossReason": {
      "type": "string",
      "enum": [
        "source_unavailable",
        "no_usable_signal",
        "low_confidence",
        "tempo_outside_range",
        "waiting_for_analysis"
      ]
    },
    "SoundStatus": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "disabled"
            }
          },
          "required": [
            "status"
          ]
        },
        {
          "type": "object",
          "properties": {
            "confidence": {
              "type": "number",
              "format": "float"
            },
            "detected_bpm": {
              "type": "number",
              "format": "double"
            },
            "status": {
              "type": "string",
              "const": "active"
            }
          },
          "required": [
            "status",
            "detected_bpm",
            "confidence"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "remaining_millis": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "status": {
              "type": "string",
              "const": "holding"
            }
          },
          "required": [
            "status",
            "reason",
            "remaining_millis"
          ]
        },
        {
          "type": "object",
          "properties": {
            "reason": {
              "$ref": "#/$defs/SoundLossReason"
            },
            "status": {
              "type": "string",
              "const": "manual_fallback"
            }
          },
          "required": [
            "status",
            "reason"
          ]
        }
      ]
    },
    "SpeedGroupRuntimeProjection": {
      "type": "object",
      "properties": {
        "beat_phase": {
          "type": "number",
          "format": "double"
        },
        "effective_bpm": {
          "type": "number",
          "format": "double"
        },
        "input_level": {
          "type": "number",
          "format": "float"
        },
        "manual_bpm": {
          "type": "number",
          "format": "double"
        },
        "paused": {
          "type": "boolean"
        },
        "phase_advancing": {
          "type": "boolean"
        },
        "phase_origin_millis": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "selected_band_level": {
          "type": "number",
          "format": "float"
        },
        "sound_bpm": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "sound_multiplier": {
          "type": "number",
          "format": "double"
        },
        "sound_status": {
          "$ref": "#/$defs/SoundStatus"
        },
        "source": {
          "$ref": "#/$defs/SpeedSource"
        },
        "source_available": {
          "type": "boolean"
        },
        "speed_master_scale": {
          "type": "number",
          "format": "double"
        },
        "synchronized_with": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        },
        "usable_signal": {
          "type": "boolean"
        }
      },
      "required": [
        "manual_bpm",
        "sound_bpm",
        "effective_bpm",
        "source",
        "sound_status",
        "paused",
        "phase_advancing",
        "speed_master_scale",
        "sound_multiplier",
        "source_available",
        "usable_signal",
        "input_level",
        "selected_band_level",
        "synchronized_with",
        "phase_origin_millis",
        "beat_phase"
      ]
    },
    "SpeedSource": {
      "type": "string",
      "enum": [
        "manual",
        "sound",
        "held_sound",
        "manual_fallback"
      ]
    }
  }
}
