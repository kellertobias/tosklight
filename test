#!/usr/bin/env bash

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UI="$ROOT/apps/control-ui"

usage(){ echo "Usage: ./test {unit|e2e|desktop-smoke|all}"; }
build_e2e(){ (cd "$UI" && npm run build); cargo build --manifest-path "$ROOT/Cargo.toml" -p light-server --no-default-features; }
unit(){ cargo test --manifest-path "$ROOT/Cargo.toml" --workspace --exclude light-control-ui --exclude light-hardware-controls --no-default-features; (cd "$UI" && npm test); }
e2e(){ build_e2e; (cd "$UI" && npm run test:e2e -- "$@"); }
desktop_smoke(){
  [[ "$(uname -s)" == Darwin ]] || { echo "desktop-smoke requires macOS" >&2; exit 2; }
  build_e2e
  (cd "$UI" && npm run tauri:build -- --debug --bundles app)
  cp "$ROOT/target/debug/light-server" "$ROOT/target/debug/bundle/macos/ToskLight.app/Contents/MacOS/light-server"
  node "$UI/e2e/desktop-smoke.mjs"
}

command="${1:-}"; shift || true
case "$command" in
  unit) unit ;;
  e2e) e2e "$@" ;;
  desktop-smoke) desktop_smoke ;;
  all) unit; e2e "$@" ;;
  *) usage >&2; exit 2 ;;
esac
